{
  "name": "contacts-web",
  "version": "0.1.0",
  "private": true,
  "license": "MPL-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:bff": "go run ./apps/bff/cmd/bff",
    "dev:integrated-local": "vite --mode integrated-local",
    "build": "vite build",
    "build:integrated-local": "vite build --mode integrated-local",
    "publish:images": "node scripts/publish-production-images.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run && go test ./apps/bff/...",
    "test:bff": "go test ./apps/bff/...",
    "test:watch": "vitest"
  },
  "dependencies": {
    "msw": "^2.14.5",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "jsdom": "^29.1.1",
    "storybook-solidjs-vite": "^10.0.13",
    "vite": "^8.0.11",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^4.1.5"
  }
}
